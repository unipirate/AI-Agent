# Recommended: configure LLM in the app UI (keys stored in system keychain).
# Optional developer fallbacks below — copy to .env and fill in values.

# --- Local mlx_lm server ---
# LLM_BASE_URL=http://localhost:8080/v1
# LLM_MODEL=

# --- Ollama ---
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:7b

# --- Cloud API keys (optional .env fallback if not set in app UI) ---
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# --- Legacy aliases ---
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini

# Web search (not configured in model switch UI yet)
TAVILY_API_KEY=

# MinerU PDF extraction (free registration at https://mineru.net/apiManage/token)
# Flash mode works without token (max 10MB/20 pages).
# Set token to enable Precision mode (max 200MB/600 pages).
# MINERU_TOKEN=

AGENT_ALLOWED_ROOT=~/Documents/AI-Agent-Sandbox
